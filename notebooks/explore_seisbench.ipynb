{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# SeismicBenchDataset: Unified Interface for All Seismic Data\n",
    "\n",
    "The `SeismicBenchDataset` provides a **unified PyTorch interface** for both:\n",
    "- Local **STEAD** data (no downloads needed)\n",
    "- Remote **SeisBench** datasets (ETHZ, GEOFON, SCEDC, etc.)\n",
    "\n",
    "This notebook demonstrates using `SeismicBenchDataset` with local STEAD data.\n",
    "For remote datasets, see [SEISBENCH_SSL_ISSUE.md](../SEISBENCH_SSL_ISSUE.md)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "%load_ext autoreload\n",
    "%autoreload 2\n",
    "%load_ext dotenv\n",
    "%dotenv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, \"../src\")\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from data import SeismicBenchDataset, plot_waveform, plot_waveform_batch\n",
    "\n",
    "%matplotlib inline\n",
    "plt.rcParams['figure.figsize'] = (12, 6)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Using SeismicBenchDataset with Local STEAD"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Loading STEAD dataset with SeismicBenchDataset...\")\n",
    "\n",
    "dataset = SeismicBenchDataset(\n",
    "    datasets='stead',\n",
    "    hdf5_path='../STEAD/merge.hdf5',\n",
    "    csv_path='../STEAD/merge.csv',\n",
    "    channel='all',\n",
    "    norm_mode='zscore',\n",
    "    trace_category='earthquake_local',\n",
    "    max_samples=200,\n",
    ")\n",
    "\n",
    "print(f\"✓ Loaded {len(dataset)} samples\")\n",
    "print(f\"\\nDataset info:\")\n",
    "print(dataset)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load a Random Sample"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "random_idx = np.random.randint(0, len(dataset))\n",
    "sample = dataset[random_idx]\n",
    "\n",
    "print(f\"Sample {random_idx}:\")\n",
    "print(f\"  Trace: {sample['trace_name']}\")\n",
    "print(f\"  Category: {sample['trace_category']}\")\n",
    "print(f\"  Magnitude: {sample['source_magnitude']}\")\n",
    "print(f\"  Distance: {sample['source_distance_km']} km\")\n",
    "print(f\"  Depth: {sample['source_depth_km']} km\")\n",
    "print(f\"  P arrival: {sample['p_arrival_sample']}\")\n",
    "print(f\"  S arrival: {sample['s_arrival_sample']}\")\n",
    "print(f\"  Waveform shape: {sample['waveform'].shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Visualize the Waveform"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["fig = plot_waveform(sample, show_arrivals=True, channels='all')\n", "plt.show()"]}
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## View with Spectrogram"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["fig = plot_waveform(sample, show_arrivals=True, show_spectrogram=True, channels='Z')\n", "plt.show()"]}
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Compare Multiple Samples"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["random_indices = np.random.choice(len(dataset), size=6, replace=False)\n", "samples = [dataset[i] for i in random_indices]\n", "\n", "fig = plot_waveform_batch(samples, ncols=3, figsize_per_plot=(5, 3), channel='Z', show_arrivals=True)\n", "plt.show()"]}
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Filter by Magnitude and Distance"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["large_eq_dataset = SeismicBenchDataset(\n", "    datasets='stead',\n", "    hdf5_path='../STEAD/merge.hdf5',\n", "    csv_path='../STEAD/merge.csv',\n", "    channel='Z',\n", "    trace_category='earthquake_local',\n", "    min_magnitude=4.0,\n", "    max_distance_km=50,\n", ")\n", "\n", "print(f\"Large earthquakes (M>=4, <50km): {len(large_eq_dataset)} samples\")"]}
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Normalization Comparison"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["norm_configs = ['none', 'zscore', 'robust_zscore', 'peak']\n", "\n", "comparison_idx = np.random.randint(0, 100)\n", "fig, axes = plt.subplots(len(norm_configs), 1, figsize=(12, 3 * len(norm_configs)))\n", "\n", "for ax, norm_mode in zip(axes, norm_configs):\n", "    ds = SeismicBenchDataset(\n", "        datasets='stead',\n", "        hdf5_path='../STEAD/merge.hdf5',\n", "        csv_path='../STEAD/merge.csv',\n", "        channel='Z',\n", "        norm_mode=norm_mode,\n", "        trace_category='earthquake_local',\n", "        max_samples=100,\n", "    )\n", "    \n", "    if comparison_idx < len(ds):\n", "        s = ds[comparison_idx]\n", "        wf = s['waveform'].numpy().flatten()\n", "        time = np.arange(len(wf)) / 100\n", "        ax.plot(time, wf, 'b', linewidth=0.5)\n", "        ax.set_title(f'{norm_mode}', fontweight='bold')\n", "        ax.grid(True, alpha=0.3)\n", "        ax.set_ylabel('Amplitude')\n", "\n", "axes[-1].set_xlabel('Time (s)')\n", "plt.tight_layout()\n", "plt.show()"]}
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Filter Comparison"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["filter_configs = {\n", "    'No filter': {'highpass_freq': None, 'lowpass_freq': None},\n", "    'High-pass 1 Hz': {'highpass_freq': 1.0},\n", "    'Low-pass 20 Hz': {'lowpass_freq': 20.0},\n", "    'Bandpass 1-10 Hz': {'highpass_freq': 1.0, 'lowpass_freq': 10.0},\n", "}\n", "\n", "fig, axes = plt.subplots(len(filter_configs), 1, figsize=(12, 3 * len(filter_configs)))\n", "\n", "for ax, (filter_name, filter_kwargs) in zip(axes, filter_configs.items()):\n", "    ds = SeismicBenchDataset(\n", "        datasets='stead',\n", "        hdf5_path='../STEAD/merge.hdf5',\n", "        csv_path='../STEAD/merge.csv',\n", "        channel='Z',\n", "        norm_mode='zscore',\n", "        trace_category='earthquake_local',\n", "        max_samples=100,\n", "        **filter_kwargs\n", "    )\n", "    \n", "    if comparison_idx < len(ds):\n", "        s = ds[comparison_idx]\n", "        wf = s['waveform'].numpy().flatten()\n", "        time = np.arange(len(wf)) / 100\n", "        ax.plot(time, wf, 'b', linewidth=0.5)\n", "        ax.set_title(f'{filter_name}', fontweight='bold')\n", "        ax.grid(True, alpha=0.3)\n", "        ax.set_ylabel('Amplitude')\n", "\n", "axes[-1].set_xlabel('Time (s)')\n", "plt.tight_layout()\n", "plt.show()"]}
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Earthquake vs Noise Comparison"
   ]
  },
  {
   "cell_type": {"code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["eq_ds = SeismicBenchDataset(\n", "    datasets='stead',\n", "    hdf5_path='../STEAD/merge.hdf5',\n", "    csv_path='../STEAD/merge.csv',\n", "    channel='Z',\n", "    trace_category='earthquake_local',\n", "    norm_mode='zscore',\n", "    highpass_freq=1.0,\n", "    lowpass_freq=40.0,\n", "    max_samples=100,\n", ")\n", "\n", "noise_ds = SeismicBenchDataset(\n", "    datasets='stead',\n", "    hdf5_path='../STEAD/merge.hdf5',\n", "    csv_path='../STEAD/merge.csv',\n", "    channel='Z',\n", "    trace_category='noise',\n", "    norm_mode='zscore',\n", "    highpass_freq=1.0,\n", "    lowpass_freq=40.0,\n", "    max_samples=100,\n", ")\n", "\n", "fig, axes = plt.subplots(2, 3, figsize=(15, 6))\n", "\n", "for i, ax in enumerate(axes[0]):\n", "    idx = np.random.randint(0, len(eq_ds))\n", "    s = eq_ds[idx]\n", "    wf = s['waveform'].numpy().flatten()\n", "    time = np.arange(len(wf)) / 100\n", "    ax.plot(time, wf, 'k', linewidth=0.5)\n", "    ax.set_title(f\"Earthquake (M={s['source_magnitude']:.1f})\", fontsize=10)\n", "    ax.set_ylabel('Amplitude')\n", "    ax.grid(True, alpha=0.3)\n", "\n", "for i, ax in enumerate(axes[1]):\n", "    idx = np.random.randint(0, len(noise_ds))\n", "    s = noise_ds[idx]\n", "    wf = s['waveform'].numpy().flatten()\n", "    time = np.arange(len(wf)) / 100\n", "    ax.plot(time, wf, 'g', linewidth=0.5)\n", "    ax.set_title('Noise', fontsize=10)\n", "    ax.set_ylabel('Amplitude')\n", "    ax.set_xlabel('Time (s)' if i == 2 else '')\n", "    ax.grid(True, alpha=0.3)\n", "\n", "plt.suptitle('Earthquake vs Noise Comparison', fontsize=12, fontweight='bold')\n", "plt.tight_layout()\n", "plt.show()"]}
  }
 ],
